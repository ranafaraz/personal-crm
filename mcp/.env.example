# --- CRM REST API (used by both transports to reach the Laravel backend) ---
CRM_BASE_URL=https://your-crm-domain.com/api/gpt/v1
CRM_API_KEY=pocrm_live_your_key_here

# --- HTTP / SSE transport (dist/http.js) — optional, stdio ignores these ----
# Port/host/path the Streamable HTTP server binds to. Keep HOST on loopback
# when a reverse proxy (nginx) terminates TLS in front of it.
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PATH=/mcp

# Bearer token clients must present (Authorization: Bearer <token>).
# Defaults to CRM_API_KEY if unset; set a dedicated value to decouple them.
MCP_BEARER_TOKEN=pocrm_live_your_key_here
